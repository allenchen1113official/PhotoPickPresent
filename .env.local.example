# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # openssl rand -base64 32

# ─── Google OAuth (連結 Google Drive) ──────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Microsoft / OneDrive OAuth (選用) ─────────────────────
# 申請：https://portal.azure.com → 應用程式註冊
# Tenant ID 填 "common" 可支援個人 Microsoft 帳號
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# ─── 資料庫 (Turso LibSQL) ──────────────────────────────────
# 本機開發：留空即可（自動使用本地 file:./data/photos.db）
# Vercel 部署：填入 Turso 資料庫資訊
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
